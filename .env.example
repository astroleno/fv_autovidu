# Vidu API Key（必填）
# 从 https://vidu.cn 获取
VIDU_API_KEY=your_api_key_here

# 或使用通用名
# API_KEY=your_api_key_here

# Yunwu API Key（尾帧生成、单帧重生）
YUNWU_API_KEY=your_yunwu_api_key_here

# ========== Feeling Video 平台（仅用于拉取数据） ==========
FEELING_API_BASE=https://dev-video-server.feeling.ltd/api
# 登录：identifier 为手机号或用户名，API 使用 identifier+password+type=password
FEELING_PHONE=your_phone_number
FEELING_USERNAME=your_username
FEELING_PASSWORD=your_password

# ========== 本地工作站 ==========
# 数据根目录（拉取的分镜数据 + 本地生成物）
DATA_ROOT=./data
# 本地后端端口
WEB_PORT=8000
