# Vidu API Key（必填）
# 从 https://vidu.cn 获取
VIDU_API_KEY=your_api_key_here

# 或使用通用名
# API_KEY=your_api_key_here

# Yunwu API Key（尾帧生成、单帧重生）
YUNWU_API_KEY=your_yunwu_api_key_here

# SD2 EditMap 第一步（云雾 OpenAI 兼容，见 scripts/sd2_pipeline/call_yunwu_editmap_sd2.mjs）
# YUNWU_BASE_URL=https://yunwu.ai/v1
# YUNWU_MODEL=claude-opus-4-6-thinking
# YUNWU_MAX_OUTPUT_TOKENS=16384
# EditMap 长 JSON（v2）建议调高，避免截断导致 JSON 解析失败
# YUNWU_EDITMAP_MAX_TOKENS=65536
# SD2 流水线：覆盖 SD2Prompter 系统提示词（默认 prompt/1_SD2Workflow/2_SD2Prompter/2_SD2Prompter-v2.md）
# SD2_PROMPTER_PROMPT=prompt/1_SD2Workflow/2_SD2Prompter/2_SD2Prompter-v2.md
# YUNWU_TIMEOUT_MS=900000

# 个人敏感项可写在项目根 .env.local（已 gitignore）；后端先加载 .env，再加载 .env.local 并覆盖同名变量。
#
# ========== Feeling Video 平台 ==========
# FEELING_API_BASE：仅未选 Profile（无 X-FV-Context-Id）时的回退；多 Profile 时各环境 URL 在 feeling_contexts.json → environments。
# 测试环境
FEELING_API_BASE=https://dev-video-server.feeling.ltd/api
# 生产环境官网为 https://www.feeling.video/ ，API 基址一般为（如需连生产请改为此行并配置对应账号）：
# FEELING_API_BASE=https://www.feeling.video/api
# 登录：identifier 为手机号或用户名，API 使用 identifier+password+type=password
FEELING_PHONE=your_phone_number
FEELING_USERNAME=your_username
FEELING_PASSWORD=your_password

# ========== Feeling 多 Profile（可选，与 feeling_contexts.json 中 credentialSource 变量名一致）==========
# JSON 里只写变量「名」；真实用户名密码填在 .env 或 .env.local（推荐 .env.local 覆盖）。
# FEELING_DEV_DEFAULT_USERNAME=
# FEELING_DEV_DEFAULT_PASSWORD=
# FEELING_PROD_DEFAULT_USERNAME=
# FEELING_PROD_DEFAULT_PASSWORD=

# ========== ElevenLabs（配音，可选）==========
# ELEVENLABS_API_KEY=your_key_here
# ELEVENLABS_BASE=https://api.elevenlabs.io

# ========== 本地工作站 ==========
# 数据根目录（拉取的分镜数据 + 本地生成物）
DATA_ROOT=./data
# 本地后端端口
WEB_PORT=8000
