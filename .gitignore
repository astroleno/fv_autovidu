# ===========================================
# fv_autovidu 项目 .gitignore
# ===========================================

# ------------ 环境与密钥 ------------
.env
.env.local
.env.*.local
*.local
*.pem
*.key
secrets/

# Feeling 多环境与 Profile 映射（可含账号变量名，勿提交私有人 copy）
# ------------ Python ------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
.eggs/
dist/
build/
eggs/
*.manifest
*.spec
# 项目 PyInstaller 配置需纳入版本库，供 CI 与本地打包使用
!fv_studio.spec
pip-log.txt
pip-delete-this-directory.txt
venv/
.venv/
env/
.env/
ENV/

# 类型检查 / 测试 / 覆盖
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/
*.cover
.tox/
.nox/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# ------------ 本地数据（拉取后的剧集/资产，勿提交） ------------
data/
# 仓库根目录 public（上传/对外静态等）；勿忽略 web/frontend/public（Vite 静态资源）
/public/

# ------------ 脚本生成输出 ------------
output/
*.log
logs/

# ------------ 编辑器和 IDE ------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# ------------ 系统文件 ------------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ------------ Node.js / 前端 ------------
node_modules/
# 勿将 pnpm 内容仓库放在仓库根目录；若误生成于此则忽略（正常应在全局 store）
.pnpm-store/
# Corepack 在仓库内缓存的 pnpm 版本（不应提交）
.corepack/
pnpm-debug.log*

# ------------ Windows 打包：CI 下载的 FFmpeg 二进制（勿提交） ------------
vendor/ffmpeg-windows/

# ------------ 其他 ------------
*.bak
*.tmp
*.temp
.cache/

# Specstory 历史记录
.specstory/
